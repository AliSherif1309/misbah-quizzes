<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Grade 10 Master Quiz | Grammar & Vocabulary</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(145deg, #e8eef4 0%, #dce3ec 100%);
            margin: 0;
            padding: 24px 16px;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        .container {
            width: 100%;
            max-width: 960px;
            margin: 0 auto;
        }

        .card {
            background: rgba(255, 255, 255, 0.98);
            border-radius: 2rem;
            box-shadow: 0 25px 45px -12px rgba(0, 0, 0, 0.25);
            padding: 28px 32px;
            transition: all 0.2s ease;
            border: 1px solid rgba(255,255,255,0.6);
        }

        #quiz-screen, #result-screen {
            display: none;
        }

        .logos-container {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
            flex-wrap: wrap;
            gap: 12px;
        }
        .logo {
            height: 58px;
            object-fit: contain;
        }

        /* MAIN TABS */
        .main-tabs {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-bottom: 28px;
        }
        .main-tab-btn {
            flex: 1;
            border: none;
            padding: 14px 20px;
            border-radius: 60px;
            font-family: 'Inter', sans-serif;
            font-weight: 800;
            font-size: 1.1rem;
            cursor: pointer;
            background: #f1f5f9;
            color: #475569;
            transition: 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
        }
        .main-tab-btn.active {
            background: white;
            color: #1e40af;
            box-shadow: 0 8px 20px rgba(30,64,175,0.15);
        }
        .tab-stats {
            background: #e2e8f0;
            padding: 4px 12px;
            border-radius: 40px;
            font-size: 0.75rem;
            font-weight: 700;
        }
        .main-tab-btn.active .tab-stats {
            background: #dbeafe;
            color: #1e3a8a;
        }

        .progress-wrapper {
            background: #f1f5f9;
            padding: 12px 20px;
            border-radius: 60px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 18px;
            margin-bottom: 28px;
            flex-wrap: wrap;
        }
        .progress-container {
            flex: 1;
            background: #e2e8f0;
            height: 10px;
            border-radius: 20px;
            overflow: hidden;
        }
        .progress-bar {
            height: 100%;
            background: linear-gradient(90deg, #2563eb, #7c3aed);
            width: 0%;
            transition: width 0.3s cubic-bezier(0.2, 0.9, 0.4, 1.1);
            border-radius: 20px;
        }
        .stats-text {
            font-weight: 700;
            background: white;
            padding: 6px 14px;
            border-radius: 40px;
            font-size: 0.85rem;
            color: #1e293b;
        }
        .stats-text span {
            color: #2563eb;
            font-size: 1.1rem;
            font-weight: 800;
        }

        .questions-grid {
            display: flex;
            flex-direction: column;
            gap: 24px;
            max-height: 56vh;
            overflow-y: auto;
            padding: 6px 4px 12px 4px;
            scroll-behavior: smooth;
        }
        .question-card {
            background: #ffffff;
            border-radius: 28px;
            padding: 20px 24px;
            border: 1px solid #e2e8f0;
            box-shadow: 0 4px 10px rgba(0,0,0,0.02);
        }
        .question-text {
            font-weight: 700;
            font-size: 1rem;
            margin-bottom: 18px;
            line-height: 1.4;
            padding-left: 14px;
            border-left: 5px solid #3b82f6;
            color: #0f172a;
        }
        .options-area {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }
        .option-btn {
            flex: 1 0 calc(50% - 12px);
            min-width: 170px;
            background: #f8fafc;
            border: 2px solid #e2e8f0;
            padding: 10px 14px;
            border-radius: 40px;
            font-family: 'Inter', monospace;
            font-weight: 500;
            font-size: 0.9rem;
            cursor: pointer;
            transition: all 0.12s;
            text-align: left;
            color: #1e293b;
        }
        .option-btn:hover:not(:disabled) {
            background: #eef2ff;
            border-color: #cbd5e1;
            transform: scale(0.97);
        }
        .correct {
            background: #dcfce7 !important;
            border-color: #22c55e !important;
            color: #14532d;
        }
        .wrong {
            background: #fee2e2 !important;
            border-color: #ef4444 !important;
            color: #991b1b;
            text-decoration: line-through;
        }
        .option-btn:disabled {
            cursor: default;
            opacity: 0.9;
        }

        .btn-main {
            background: linear-gradient(105deg, #2563eb, #4f46e5);
            color: white;
            border: none;
            padding: 14px 32px;
            border-radius: 60px;
            font-weight: 700;
            font-size: 1rem;
            cursor: pointer;
            transition: 0.2s;
            font-family: 'Inter', sans-serif;
            box-shadow: 0 6px 14px rgba(37,99,235,0.3);
        }
        .btn-main:hover {
            transform: translateY(-2px);
            filter: brightness(1.02);
        }
        .btn-secondary {
            background: #334155;
            box-shadow: none;
        }
        input {
            width: 85%;
            padding: 14px 20px;
            border-radius: 60px;
            border: 2px solid #e2e8f0;
            font-family: 'Inter', sans-serif;
            font-size: 1rem;
            text-align: center;
            background: #fefefe;
            margin-bottom: 20px;
        }
        input:focus {
            outline: none;
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59,130,246,0.2);
        }
        .result-buttons {
            display: flex;
            justify-content: center;
            gap: 18px;
            margin-top: 28px;
            flex-wrap: wrap;
        }
        h1 {
            font-size: 1.9rem;
            font-weight: 800;
            background: linear-gradient(135deg, #1e293b, #2563eb);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
            margin-bottom: 0.25rem;
        }
        .subhead {
            color: #475569;
            font-weight: 500;
            margin-bottom: 1.5rem;
        }
        footer {
            font-size: 0.7rem;
            text-align: center;
            margin-top: 1rem;
            color: #64748b;
        }
        @media (max-width: 680px) {
            .card { padding: 20px; }
            .option-btn { flex: 1 0 100%; }
            .main-tabs { flex-direction: column; gap: 10px; }
            .main-tab-btn { justify-content: space-between; }
        }
    </style>
</head>
<body>
<div class="container">
    <!-- WELCOME SCREEN -->
    <div id="welcome-screen" class="card">
        <div class="logos-container">
            <img src="neu-logo.png" class="logo" id="logo-neu" alt="logo" onerror="this.style.display='none'">
            <img src="lights-logo.png" class="logo" id="logo-lights" alt="logo" onerror="this.style.display='none'">
        </div>
        <h1>📘 Grade 10 Quiz</h1>
        <div class="subhead">Unit 12: Grammar & Vocabulary</div>
        <p style="margin-bottom: 16px;">Teacher: Mr. Ali Misbah</p>
        <input type="text" id="student-name" placeholder="Enter your full name" autocomplete="off">
        <br>
        <button class="btn-main" onclick="initiateQuiz()">✨ Start Quiz ✨</button>
        <footer>28 questions (Grammar + Vocabulary) | certificate included</footer>
    </div>

    <!-- QUIZ SCREEN (with main tabs) -->
    <div id="quiz-screen" class="card">
        <div class="logos-container" style="margin-bottom: 8px;">
            <div style="font-weight:800; background:#eef2ff; padding:5px 15px; border-radius:40px;">🎓 Grade 10 Challenge</div>
            <div style="font-size:0.8rem;">🎯 Mr. Ali Misbah</div>
        </div>

        <!-- Main Tabs: Grammar / Vocabulary -->
        <div class="main-tabs">
            <button class="main-tab-btn active" data-main="grammar" onclick="switchMainTab('grammar')">
                📖 Grammar
                <span class="tab-stats" id="grammar-stats">0/9 ✅ 0</span>
            </button>
            <button class="main-tab-btn" data-main="vocab" onclick="switchMainTab('vocab')">
                📚 Vocabulary
                <span class="tab-stats" id="vocab-stats">0/19 ✅ 0</span>
            </button>
        </div>
        
        <div class="progress-wrapper">
            <div class="progress-container">
                <div class="progress-bar" id="global-progress"></div>
            </div>
            <div class="stats-text">🏆 Total Score: <span id="total-score-span">0</span> / <span id="total-questions-count">28</span></div>
        </div>

        <div id="questions-container" class="questions-grid"></div>
    </div>

    <!-- RESULT SCREEN -->
    <div id="result-screen" class="card">
        <div style="font-size: 70px; text-align:center;">🏅</div>
        <h1 id="rank-slot" style="text-align:center;">Master Achiever</h1>
        <h2 id="final-score" style="text-align:center; margin: 10px 0;"></h2>
        <div class="result-buttons">
            <button class="btn-main" onclick="downloadCertificate()" style="background:#0f172a;">📜 Download Certificate</button>
            <button class="btn-main btn-secondary" onclick="resetFullQuiz()">🔄 Try Again</button>
        </div>
    </div>
</div>

<audio id="snd-correct" preload="auto" src="https://assets.mixkit.co/active_storage/sfx/2000/2000-preview.mp3"></audio>
<audio id="snd-wrong" preload="auto" src="https://assets.mixkit.co/active_storage/sfx/2003/2003-preview.mp3"></audio>
<audio id="snd-win" preload="auto" src="https://assets.mixkit.co/active_storage/sfx/1435/1435-preview.mp3"></audio>

<script>
    const { jsPDF } = window.jspdf;
    
    // ======================= GRADE 10 QUESTIONS =======================
    // GRAMMAR (9 questions)
    const GRAMMAR_QS = [
        { id: 0, text: "1. If he ................ slowly, the accident wouldn't have happened.", options: ["Drives", "drove", "had given", "will drive"], correct: 2, main: "grammar" },
        { id: 1, text: "2. We ................ by taxi if we had found the right bus.", options: ["came", "won't come", "wouldn't have come", "would come"], correct: 2, main: "grammar" },
        { id: 2, text: "3. The man ................ sent you this letter is my cousin.", options: ["who", "whose", "where", "which"], correct: 0, main: "grammar" },
        { id: 3, text: "4. This is the house ................ Omar lives.", options: ["whose", "where", "who", "which"], correct: 1, main: "grammar" },
        { id: 4, text: "5. The man ................ the car hit him yesterday, was hospitalised immediately.", options: ["whose", "which", "whom", "when"], correct: 2, main: "grammar" },
        { id: 5, text: "6. If she ................ the map, she wouldn't have gotten lost.", options: ["uses", "used", "had used", "will use"], correct: 2, main: "grammar" },
        { id: 6, text: "7. They ................ the match if the referee hadn't made that mistake.", options: ["win", "won", "would have won", "would win"], correct: 2, main: "grammar" },
        { id: 7, text: "8. I met the famous writer ................ stories are well-known worldwide.", options: ["who", "whom", "where", "whose"], correct: 3, main: "grammar" },
        { id: 8, text: "9. If I had to borrow some money, I ................ my elder brother.", options: ["will ask", "would have asked", "would ask", "am asking"], correct: 2, main: "grammar" }
    ];
    
    // VOCABULARY (19 questions combined from 3 sets)
    const VOCAB_QS = [
        // Set 1 (8)
        { id: 9, text: "1. Modern ................ has made the world smaller by bringing people and cultures closer.", options: ["aviation", "gliding", "instructors", "ring"], correct: 0, main: "vocab" },
        { id: 10, text: "2. ................ is an exciting sport that lets you fly without an engine.", options: ["aviation", "instructor", "ring", "gliding"], correct: 3, main: "vocab" },
        { id: 11, text: "3. My sister focused ................ on her studies to prepare for the exam.", options: ["Exemplary", "intensely", "briefly", "crazily"], correct: 1, main: "vocab" },
        { id: 12, text: "4. Schools reward students who show ................ behaviour during the school year.", options: ["exemplary", "portable", "urgent", "impromptu"], correct: 0, main: "vocab" },
        { id: 13, text: "5. Children should be taught to behave ................ and kindly towards other people.", options: ["courteously", "notably", "intensely", "briefly"], correct: 0, main: "vocab" },
        { id: 14, text: "6. The teacher spoke in a ................ voice to stop the noise.", options: ["stunned", "stern", "exemplary", "confrontational"], correct: 1, main: "vocab" },
        { id: 15, text: "7. My friend closely ................ her mother in both looks and personality.", options: ["coincides with", "unlocks", "mumbles", "resembles"], correct: 3, main: "vocab" },
        { id: 16, text: "8. The seats of the plane were comfortable, and the flight ................ were friendly and helpful.", options: ["attendants", "expressions", "instructors", "cabins"], correct: 0, main: "vocab" },
        // Set 2 (6)
        { id: 17, text: "9. The plane usually flies at an ................ of more than 16 thousand feet.", options: ["radar", "headline", "altitude", "fog"], correct: 2, main: "vocab" },
        { id: 18, text: "10. My family ordered a/an ................ table for the dining room.", options: ["custom-built", "voice-activated", "stern", "stunned"], correct: 0, main: "vocab" },
        { id: 19, text: "11. Learning how to ................ is an important aspect of pilot training.", options: ["mumble", "endeavour", "aviate", "resemble"], correct: 2, main: "vocab" },
        { id: 20, text: "12. The ................ of the news grabbed my attention with an interesting story.", options: ["velocity", "control", "eyewitness", "headline"], correct: 3, main: "vocab" },
        { id: 21, text: "13. You should ................ an expert before starting your own business.", options: ["smuggle", "consult", "recharge", "slide"], correct: 1, main: "vocab" },
        { id: 22, text: "14. All the passengers cheered loudly when the plane ................", options: ["set off", "touched down", "knocked off", "dropped off"], correct: 1, main: "vocab" },
        // Set 3 (5)
        { id: 23, text: "15. The club celebrated its 21st ................ with a special event for its fans and players.", options: ["frequency", "current", "anniversary", "congestion"], correct: 2, main: "vocab" },
        { id: 24, text: "16. Safety measures should be taken in the science lab to avoid ................ situations.", options: ["acclaimed", "affluent", "portable", "hazardous"], correct: 3, main: "vocab" },
        { id: 25, text: "17. It is a smart move towards a better future to ................ in renewable energy companies.", options: ["slide", "invest", "mumble", "draw"], correct: 1, main: "vocab" },
        { id: 26, text: "18. Unluckily, a boy was ................ his bike by a careless driver as he was crossing the road.", options: ["knocked off", "turned up", "set off", "ended up with"], correct: 0, main: "vocab" },
        { id: 27, text: "19. The flight ................ provided excellent service to the passengers throughout the journey.", options: ["auction", "breakdown", "hassle", "attendant"], correct: 3, main: "vocab" }
    ];
    
    const ALL_QUESTIONS = [...GRAMMAR_QS, ...VOCAB_QS];
    const TOTAL_QS = ALL_QUESTIONS.length;
    
    let studentName = "";
    let userAnswers = new Array(TOTAL_QS).fill(null);
    let currentMain = "grammar";   // 'grammar' or 'vocab'
    
    // DOM elements
    const welcomeScreen = document.getElementById('welcome-screen');
    const quizScreen = document.getElementById('quiz-screen');
    const resultScreen = document.getElementById('result-screen');
    const questionsContainer = document.getElementById('questions-container');
    const globalProgress = document.getElementById('global-progress');
    const totalScoreSpan = document.getElementById('total-score-span');
    const totalQtySpan = document.getElementById('total-questions-count');
    
    // Helper: compute stats per main category and overall
    function computeStats() {
        let grammarDone = 0, grammarCorrect = 0;
        let vocabDone = 0, vocabCorrect = 0;
        let overallCorrect = 0, overallDone = 0;
        
        ALL_QUESTIONS.forEach(q => {
            const ans = userAnswers[q.id];
            const isAnswered = ans !== null;
            if (isAnswered) {
                overallDone++;
                const isRight = (ans === q.correct);
                if (isRight) overallCorrect++;
                
                if (q.main === "grammar") {
                    grammarDone++;
                    if (isRight) grammarCorrect++;
                } else {
                    vocabDone++;
                    if (isRight) vocabCorrect++;
                }
            }
        });
        return { grammarDone, grammarCorrect, vocabDone, vocabCorrect, overallCorrect, overallDone };
    }
    
    function updateUIStats() {
        const stats = computeStats();
        document.getElementById('grammar-stats').innerHTML = `${stats.grammarDone}/9 ✅ ${stats.grammarCorrect}`;
        document.getElementById('vocab-stats').innerHTML = `${stats.vocabDone}/19 ✅ ${stats.vocabCorrect}`;
        totalScoreSpan.innerText = stats.overallCorrect;
        const percent = (stats.overallDone / TOTAL_QS) * 100;
        globalProgress.style.width = percent + "%";
        return stats;
    }
    
    // Render current main tab questions
    function renderCurrentTab() {
        if (!questionsContainer) return;
        const filtered = ALL_QUESTIONS.filter(q => q.main === currentMain);
        questionsContainer.innerHTML = "";
        
        filtered.forEach(q => {
            const card = document.createElement('div');
            card.className = 'question-card';
            const qText = document.createElement('div');
            qText.className = 'question-text';
            // Show original numbering (1-9 for grammar, 1-19 for vocab) - but keep id display clean
            let displayNum = q.id + 1;
            if (currentMain === 'grammar') displayNum = q.id - 0 + 1;
            else displayNum = q.id - 8;  // vocab starts at id 9 -> display 1
            qText.innerText = `${displayNum}. ${q.text}`;
            card.appendChild(qText);
            
            const optsDiv = document.createElement('div');
            optsDiv.className = 'options-area';
            q.options.forEach((opt, idx) => {
                const btn = document.createElement('button');
                btn.className = 'option-btn';
                btn.innerText = `${String.fromCharCode(65+idx)}. ${opt}`;
                const isAnswered = userAnswers[q.id] !== null;
                if (isAnswered) {
                    btn.disabled = true;
                    if (idx === q.correct) btn.classList.add('correct');
                    if (idx === userAnswers[q.id] && idx !== q.correct) btn.classList.add('wrong');
                } else {
                    btn.onclick = () => handleAnswer(q.id, idx);
                }
                optsDiv.appendChild(btn);
            });
            card.appendChild(optsDiv);
            questionsContainer.appendChild(card);
        });
    }
    
    function handleAnswer(qId, selectedIdx) {
        if (userAnswers[qId] !== null) return;
        const question = ALL_QUESTIONS.find(q => q.id === qId);
        const isCorrect = (selectedIdx === question.correct);
        const sound = document.getElementById(isCorrect ? 'snd-correct' : 'snd-wrong');
        if (sound) sound.play().catch(e=>{});
        userAnswers[qId] = selectedIdx;
        renderCurrentTab();
        const stats = updateUIStats();
        if (stats.overallDone === TOTAL_QS) {
            setTimeout(() => showResultsScreen(), 500);
        }
    }
    
    function switchMainTab(main) {
        currentMain = main;
        document.querySelectorAll('.main-tab-btn').forEach(btn => {
            if (btn.getAttribute('data-main') === main) btn.classList.add('active');
            else btn.classList.remove('active');
        });
        renderCurrentTab();
    }
    
    function initiateQuiz() {
        const nameInput = document.getElementById('student-name');
        const raw = nameInput.value.trim();
        if (raw === "") {
            alert("Please enter your name to begin.");
            return;
        }
        studentName = raw;
        userAnswers = new Array(TOTAL_QS).fill(null);
        currentMain = "grammar";
        document.querySelectorAll('.main-tab-btn').forEach(btn => {
            if (btn.getAttribute('data-main') === 'grammar') btn.classList.add('active');
            else btn.classList.remove('active');
        });
        updateUIStats();
        renderCurrentTab();
        welcomeScreen.style.display = 'none';
        quizScreen.style.display = 'block';
        resultScreen.style.display = 'none';
        if (questionsContainer) questionsContainer.scrollTop = 0;
    }
    
    function showResultsScreen() {
        const stats = computeStats();
        const percent = Math.round((stats.overallCorrect / TOTAL_QS) * 100);
        let rank = "";
        if (stats.overallCorrect === TOTAL_QS) rank = "🏅 PERFECT SCHOLAR 🏅";
        else if (stats.overallCorrect >= 23) rank = "🌟 Excellence Award 🌟";
        else if (stats.overallCorrect >= 18) rank = "📚 Proficient Achiever";
        else rank = "📖 Keep Growing!";
        document.getElementById('rank-slot').innerHTML = rank;
        document.getElementById('final-score').innerHTML = `🎯 Score: ${stats.overallCorrect} / ${TOTAL_QS}  (${percent}%)`;
        quizScreen.style.display = 'none';
        resultScreen.style.display = 'block';
        const win = document.getElementById('snd-win');
        if (win) win.play().catch(e=>{});
        canvasConfetti({ particleCount: 220, spread: 85, origin: { y: 0.6 }, colors: ['#2563eb', '#4f46e5', '#f59e0b'] });
        canvasConfetti({ particleCount: 70, spread: 120, origin: { y: 0.4, x: 0.3 }, startVelocity: 15 });
    }
    
    function resetFullQuiz() {
        studentName = "";
        userAnswers = new Array(TOTAL_QS).fill(null);
        document.getElementById('student-name').value = "";
        welcomeScreen.style.display = 'block';
        quizScreen.style.display = 'none';
        resultScreen.style.display = 'none';
        updateUIStats();
        globalProgress.style.width = "0%";
        currentMain = "grammar";
        document.querySelectorAll('.main-tab-btn').forEach(btn => {
            if (btn.getAttribute('data-main') === 'grammar') btn.classList.add('active');
            else btn.classList.remove('active');
        });
    }
    
    function downloadCertificate() {
        if (!studentName) {
            const fallback = document.getElementById('student-name')?.value.trim();
            if (fallback) studentName = fallback;
            else studentName = "Ambitious Student";
        }
        const stats = computeStats();
        const percent = Math.round((stats.overallCorrect / TOTAL_QS) * 100);
        const doc = new jsPDF({ orientation: 'landscape', unit: 'mm', format: 'a4' });
        const w = 297, h = 210;
        doc.setFillColor(240, 248, 255);
        doc.rect(0, 0, w, h, 'F');
        doc.setDrawColor(37, 99, 235);
        doc.setLineWidth(2);
        doc.rect(10, 10, w - 20, h - 20);
        
        doc.setFont("helvetica", "bold");
        doc.setFontSize(32);
        doc.setTextColor(30, 41, 59);
        doc.text("CERTIFICATE OF ACHIEVEMENT", w/2, 55, { align: "center" });
        
        doc.setFont("helvetica", "normal");
        doc.setFontSize(18);
        doc.setTextColor(71, 85, 105);
        doc.text("This certificate is proudly presented to", w/2, 80, { align: "center" });
        
        doc.setFont("helvetica", "bold");
        doc.setFontSize(34);
        doc.setTextColor(37, 99, 235);
        doc.text(studentName.toUpperCase(), w/2, 110, { align: "center" });
        
        doc.setFont("helvetica", "normal");
        doc.setFontSize(16);
        doc.setTextColor(51, 65, 85);
        doc.text(`for outstanding performance in Grade 10 English (Unit 12)`, w/2, 138, { align: "center" });
        doc.text(`Grammar & Vocabulary Mastery`, w/2, 152, { align: "center" });
        
        doc.setFontSize(20);
        doc.setFont("helvetica", "bold");
        doc.setTextColor(22, 163, 74);
        doc.text(`Final Score: ${stats.overallCorrect} / ${TOTAL_QS}  ·  ${percent}%`, w/2, 172, { align: "center" });
        
        doc.setFontSize(12);
        doc.setFont("helvetica", "italic");
        doc.setTextColor(100, 116, 139);
        doc.text(`Date: ${new Date().toLocaleDateString()}`, w/2, 190, { align: "center" });
        
        doc.setFont("helvetica", "bold");
        doc.setFontSize(14);
        doc.setTextColor(15, 23, 42);
        doc.text("Mr. Ali Misbah", w/2, 202, { align: "center" });
        doc.setFontSize(10);
        doc.text("English Language Instructor", w/2, 208, { align: "center" });
        
        doc.save(`${studentName.replace(/\s/g, "_")}_Grade10_Certificate.pdf`);
    }
    
    totalQtySpan.innerText = TOTAL_QS;
    window.initiateQuiz = initiateQuiz;
    window.switchMainTab = switchMainTab;
    window.resetFullQuiz = resetFullQuiz;
    window.downloadCertificate = downloadCertificate;
    
    document.addEventListener('DOMContentLoaded', () => {
        updateUIStats();
    });
</script>
